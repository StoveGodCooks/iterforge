{
  "name": "iterforge",
  "version": "1.0.0",
  "description": "IterForge - Game Asset Generation Pipeline Orchestrator",
  "author": "StoveGodCooks",
  "main": "electron-main.js",
  "bin": {
    "iterforge": "bin/iterforge.js"
  },
  "scripts": {
    "start": "node bin/iterforge.js",
    "test": "node test/runner.js",
    "app": "node launcher.js",
    "dev:server": "node src/server/dev-server.js",
    "dev:frontend": "npm --prefix frontend run dev",
    "build:frontend": "npm --prefix frontend run build",
    "gui": "electron .",
    "build:exe": "npm run build:frontend && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --publish never",
    "build:mac": "npm run build:frontend && electron-builder --mac --publish never",
    "build:linux": "npm run build:frontend && electron-builder --linux --publish never",
    "build:all": "npm run build:frontend && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --mac --linux --publish never"
  },
  "build": {
    "appId": "com.iterforge.app",
    "productName": "IterForge",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron-main.js",
      "bin/**",
      "src/**",
      "comfyui-workflows/**",
      "frontend/dist/**",
      "assets/icon.ico",
      "assets/icon.png",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "IterForge-Setup-${version}.exe"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "IterForge-${version}.dmg",
      "category": "public.app-category.graphics-design"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "IterForge-${version}.AppImage",
      "category": "Graphics"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "IterForge"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.0.4",
    "chalk": "^5.0.0",
    "commander": "^12.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "fs-extra": "^11.2.0",
    "multer": "^2.1.1",
    "node-fetch": "3.3.2",
    "open": "^11.0.0",
    "ora": "^8.0.0",
    "sharp": "0.33.3"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "30.0.9",
    "electron-builder": "24.13.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module"
}
