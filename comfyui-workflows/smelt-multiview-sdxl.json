{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "__CKPT_NAME__" }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "__PROMPT_POSITIVE__", "clip": ["1", 1] }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "__PROMPT_NEGATIVE__", "clip": ["1", 1] }
  },
  "4": {
    "class_type": "LoadImage",
    "inputs": { "image": "__REFERENCE_IMAGE__" }
  },
  "5": {
    "class_type": "VAEEncode",
    "inputs": { "pixels": ["4", 0], "vae": ["1", 2] }
  },

  "10": {
    "class_type": "IPAdapterModelLoader",
    "inputs": { "ipadapter_file": "ip-adapter_sdxl_vit-h.safetensors" }
  },
  "11": {
    "class_type": "CLIPVisionLoader",
    "inputs": { "clip_name": "CLIP-ViT-H-14-laion2B-s32B-b79K.safetensors" }
  },
  "12": {
    "class_type": "IPAdapterAdvanced",
    "inputs": {
      "model":        ["1", 0],
      "ipadapter":    ["10", 0],
      "image":        ["4", 0],
      "clip_vision":  ["11", 0],
      "weight":       "__IPADAPTER_WEIGHT__",
      "weight_type":  "linear",
      "start_at":     0.0,
      "end_at":       1.0,
      "unfold_batch": false
    }
  },

  "20": {
    "class_type": "DepthAnythingV2Preprocessor",
    "inputs": {
      "image":      ["4", 0],
      "ckpt_name":  "depth_anything_v2_vitl.pth",
      "resolution": 512
    }
  },
  "21": {
    "class_type": "ControlNetLoader",
    "inputs": { "control_net_name": "controlnet-depth-sdxl.safetensors" }
  },
  "22": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive":      ["2", 0],
      "negative":      ["3", 0],
      "control_net":   ["21", 0],
      "image":         ["20", 0],
      "strength":      0.6,
      "start_percent": 0.0,
      "end_percent":   0.55
    }
  },

  "30": {
    "class_type": "CannyEdgePreprocessor",
    "inputs": {
      "image":          ["4", 0],
      "low_threshold":  100,
      "high_threshold": 200,
      "resolution":     512
    }
  },
  "31": {
    "class_type": "ControlNetLoader",
    "inputs": { "control_net_name": "controlnet-canny-sdxl.safetensors" }
  },
  "32": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive":      ["22", 0],
      "negative":      ["22", 1],
      "control_net":   ["31", 0],
      "image":         ["30", 0],
      "strength":      0.35,
      "start_percent": 0.35,
      "end_percent":   1.0
    }
  },

  "40": {
    "class_type": "KSampler",
    "inputs": {
      "model":        ["12", 0],
      "positive":     ["32", 0],
      "negative":     ["32", 1],
      "latent_image": ["5", 0],
      "seed":         "__SEED__",
      "steps":        "__STEPS__",
      "cfg":          "__CFG__",
      "sampler_name": "dpmpp_2m",
      "scheduler":    "karras",
      "denoise":      "__STRENGTH__"
    }
  },
  "41": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["40", 0], "vae": ["1", 2] }
  },
  "99": {
    "class_type": "SaveImage",
    "inputs": { "images": ["41", 0], "filename_prefix": "iterforge" }
  }
}
