{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "__CKPT_NAME__" }
  },
  "8": {
    "_comment": "LoRA loader — bypassed at runtime when no LoRA available",
    "class_type": "LoraLoader",
    "inputs": {
      "model":          ["1", 0],
      "clip":           ["1", 1],
      "lora_name":      "__LORA_NAME__",
      "strength_model": "__LORA_STRENGTH__",
      "strength_clip":  "__LORA_STRENGTH__"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "__PROMPT_POSITIVE__", "clip": ["8", 1] }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "__PROMPT_NEGATIVE__", "clip": ["8", 1] }
  },
  "4": {
    "class_type": "EmptyLatentImage",
    "inputs": { "width": "__WIDTH__", "height": "__HEIGHT__", "batch_size": 1 }
  },
  "9": {
    "class_type": "ControlNetLoader",
    "inputs": { "control_net_name": "__CONTROLNET_MODEL__" }
  },
  "10": {
    "class_type": "LoadImage",
    "inputs": { "image": "__CONTROLNET_IMAGE__" }
  },
  "11": {
    "_comment": "DWPose preprocessor — extracts skeleton from reference image",
    "class_type": "DWPreprocessor",
    "inputs": {
      "image":          ["10", 0],
      "detect_hand":    "enable",
      "detect_body":    "enable",
      "detect_face":    "enable",
      "resolution":     512
    }
  },
  "12": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive":      ["2", 0],
      "negative":      ["3", 0],
      "control_net":   ["9", 0],
      "image":         ["11", 0],
      "strength":      "__CONTROLNET_STRENGTH__",
      "start_percent": 0.0,
      "end_percent":   1.0
    }
  },
  "5": {
    "class_type": "KSampler",
    "inputs": {
      "model":        ["8", 0],
      "positive":     ["12", 0],
      "negative":     ["12", 1],
      "latent_image": ["4", 0],
      "seed":         "__SEED__",
      "steps":        "__STEPS__",
      "cfg":          "__CFG__",
      "sampler_name": "dpmpp_2m_sde",
      "scheduler":    "karras",
      "denoise":      1.0
    }
  },
  "6": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["5", 0], "vae": ["1", 2] }
  },
  "7": {
    "class_type": "SaveImage",
    "inputs": { "images": ["6", 0], "filename_prefix": "iterforge" }
  }
}
