{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "__CKPT_NAME__" }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "__PROMPT_POSITIVE__", "clip": ["1", 1] }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "__PROMPT_NEGATIVE__", "clip": ["1", 1] }
  },
  "4": {
    "class_type": "LoadImage",
    "inputs": { "image": "__REFERENCE_IMAGE__" }
  },
  "5": {
    "class_type": "UpscaleModelLoader",
    "inputs": { "model_name": "__UPSCALE_MODEL__" }
  },
  "6": {
    "_comment": "UltimateSDUpscale — tiles the image to avoid VRAM explosion",
    "class_type": "UltimateSDUpscale",
    "inputs": {
      "upscale_model":    ["5", 0],
      "image":            ["4", 0],
      "model":            ["1", 0],
      "positive":         ["2", 0],
      "negative":         ["3", 0],
      "vae":              ["1", 2],
      "upscale_by":       "__UPSCALE_FACTOR__",
      "seed":             "__SEED__",
      "steps":            "__STEPS__",
      "cfg":              "__CFG__",
      "sampler_name":     "dpmpp_2m_sde",
      "scheduler":        "karras",
      "denoise":          0.35,
      "mode_type":        "Linear",
      "tile_width":       512,
      "tile_height":      512,
      "mask_blur":        8,
      "tile_padding":     32,
      "seam_fix_mode":    "None",
      "seam_fix_denoise": 0.35,
      "seam_fix_width":   64,
      "seam_fix_mask_blur": 8,
      "seam_fix_padding": 16,
      "force_uniform_tiles": true,
      "tiled_decode":     false
    }
  },
  "7": {
    "class_type": "SaveImage",
    "inputs": { "images": ["6", 0], "filename_prefix": "iterforge_upscaled" }
  }
}
